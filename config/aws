[profile port-aws-infra]
region = ap-northeast-2
credential_process = bash -c "saml2aws login --skip-prompt --username=leslie --password=$PORT_KEYCLOAK_PW --credential-process -a port-aws-infra --mfa-token=$(oathtool --base32 $PORT_KEYCLOAK_OTP --totp)"

