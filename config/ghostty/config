font-family = "Cascadia Code NF"
font-size = 8
font-feature = -calt
font-feature = -liga
font-feature = -dlig

window-theme = auto
theme = light:Adwaita,dark:Tomorrow Night Bright
window-show-tab-bar = never
window-padding-x = 4
window-padding-y = 4

confirm-close-surface = false

# Use xterm-256color so ssh into hosts without ghostty terminfo doesn't
# break backspace/undo/arrows. Loses truecolor and curly underlines.
term = xterm-256color

# zellij handles multiplexing inside the terminal.
# All ghostty defaults are dropped and only essentials are re-added,
# so tab/split shortcuts cannot be triggered accidentally.
keybind = clear
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+insert=copy_to_clipboard
keybind = shift+insert=paste_from_selection
keybind = ctrl+==increase_font_size:1
keybind = ctrl++=increase_font_size:1
keybind = ctrl+-=decrease_font_size:1
keybind = ctrl+0=reset_font_size
keybind = ctrl+shift+comma=reload_config
keybind = ctrl+shift+minus=text:\x1f
