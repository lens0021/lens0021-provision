/node_modules
/cache/*
!/cache/.gitkeep

__pycache__

# Rust plugin build output (the built .wasm is committed alongside its crate)
/config/zellij-plugins/*/target/

# Local scratch (registry snapshots, etc.)
/.tmp/

# Claude Code per-machine state
/.claude/settings.local.json
/.claude/translations.log
/.claude/translations.log.lock
